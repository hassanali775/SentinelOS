# ══════════════════════════════════════════════
# SentinelOS — Environment Configuration
# ══════════════════════════════════════════════
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.

# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
APP_ENV=development
APP_NAME=SentinelOS
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO

# ──────────────────────────────────────────────
# Control Plane API
# ──────────────────────────────────────────────
CONTROL_PLANE_HOST=0.0.0.0
CONTROL_PLANE_PORT=8000
CONTROL_PLANE_WORKERS=1

# ──────────────────────────────────────────────
# PostgreSQL — Event Store
# ──────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sentinelos
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel_secret
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
POSTGRES_POOL_TIMEOUT=30

# Assembled by settings.py — do not set manually
# DATABASE_URL=postgresql+asyncpg://sentinel:sentinel_secret@localhost:5432/sentinelos

# ──────────────────────────────────────────────
# Redpanda (Kafka-compatible)
# ──────────────────────────────────────────────
REDPANDA_BROKERS=localhost:19092
REDPANDA_TOPIC_AGENT_EVENTS=sentinel.agent.events
REDPANDA_TOPIC_DLQ=sentinel.agent.events.dlq
REDPANDA_CONSUMER_GROUP=sentinel-control-plane
REDPANDA_WORKER_CONSUMER_GROUP=sentinel-runtime-worker

# ──────────────────────────────────────────────
# OpenTelemetry
# ──────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=sentinelos-control-plane
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACE_SAMPLE_RATE=1.0

# ──────────────────────────────────────────────
# Ollama (Local LLM Runtime)
# ──────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_TIMEOUT_SECONDS=120
